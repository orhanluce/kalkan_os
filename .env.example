# Bu dosya ŞABLONDUR ve commit edilir — gerçek anahtarları BURAYA YAZMA.
# Kopyala: cp .env.example .env.local  ve değerleri .env.local'e gir.
# .env.local .gitignore'da (CLAUDE.md kural 7: gizli anahtarlar yalnızca .env).

# --- Uygulama (tarayıcıya gider, gizli değil) ---
# Supabase panelinde: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sunucu tarafı: GİZLİ, ASLA tarayıcıya sızmamalı ---
# RLS'i BYPASS eder. Yalnızca seed/migration gibi sunucu işlerinde kullanılır.
# Sızarsa tüm kiracıların verisi açılır — bir uyum ürünü için felaket.
SUPABASE_SERVICE_ROLE_KEY=

# --- Migration'ları uygulamak için (pnpm db:push) ---
# Kişisel erişim token'ı: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Veritabanı şifresi: proje kurulurken belirlediğin şifre.
# Unuttuysan: Project Settings → Database → Reset database password
SUPABASE_DB_PASSWORD=
# Session pooler host (Connect → Session pooler → URI'deki host kısmı).
# Direct connection IPv6-only olduğu için IPv4 ağlardan (çoğu ev/ofis ağı)
# bağlanmak buna gerekli — bkz. panelde "Direct connections use IPv6 by default".
SUPABASE_DB_POOLER_HOST=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- E2E test fikstürü (pnpm exec tsx scripts/setup-e2e-fixtures.ts doldurur) ---
# Bunlar bir insanın kimlik bilgileri DEĞİL: script tarafından üretilen, yalnızca
# ayrı "E2E Test Kurumu A.Ş." kiracısına bağlı, atılabilir test hesaplarıdır.
# Elle doldurma — script kriptografik olarak rastgele şifre üretip buraya yazar.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_USER2_EMAIL=
E2E_USER2_PASSWORD=
